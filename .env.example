# 服务器配置
PORT=3000

# SQL Server 数据库配置（请根据实际情况修改）
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=your_sqlserver_password
DB_NAME=yaotianxia
# 是否加密连接（Azure SQL 等云端需设为 true，本地通常为 false）
DB_ENCRYPT=false
# 是否信任自签名证书（本地开发设为 true，生产环境建议设为 false）
DB_TRUST_CERT=true

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=yaotianxia_jwt_secret_2024_change_this

# Session 密钥
SESSION_SECRET=yaotianxia_session_secret_2024

# 前端地址（开发环境）
FRONTEND_URL=http://localhost:5173

# 前端 API 地址（生产环境可留空，使用相对路径）
VITE_API_URL=http://localhost:3000/api
