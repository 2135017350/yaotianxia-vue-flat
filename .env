# 服务器配置
PORT=3000

# MySQL 数据库配置（请根据实际情况修改）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=yaotianxia

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=yaotianxia_jwt_secret_2024_change_this

# Session 密钥
SESSION_SECRET=yaotianxia_session_secret_2024

# 前端地址（生产模式：前后端同端口）
FRONTEND_URL=http://localhost:3000

# 前端 API 地址
# 开发模式（pnpm dev）：使用 Vite 代理，留空或使用相对路径 /api
# 生产模式（pnpm build + node server/index.js）：留空，使用相对路径
VITE_API_URL=

# 邮件配置（用于发送客户咨询留言）
# 主要接收邮箱（客户留言将发送到此邮箱）
MAIL_TO=2135017350@qq.com

# SMTP 服务配置（支持多个邮箱服务）
# 格式：MAIL_SMTP_<服务名>=host:port:user:pass
# 示例：
# QQ 邮箱：MAIL_SMTP_QQ=smtp.qq.com:465:your_email@qq.com:your_auth_code
# 163 邮箱：MAIL_SMTP_163=smtp.163.com:465:your_email@163.com:your_password
# Gmail：MAIL_SMTP_GMAIL=smtp.gmail.com:587:your_email@gmail.com:your_app_password

# 默认使用的 SMTP 服务（QQ、163、GMAIL 等）
MAIL_SMTP_SERVICE=QQ

# QQ 邮箱 SMTP 配置（需要在 QQ 邮箱设置中开启 SMTP 并获取授权码）
MAIL_SMTP_QQ_HOST=smtp.qq.com
MAIL_SMTP_QQ_PORT=465
MAIL_SMTP_QQ_USER=2135017350@qq.com
MAIL_SMTP_QQ_PASS=your_qq_auth_code_here

# 163 邮箱 SMTP 配置（可选）
MAIL_SMTP_163_HOST=smtp.163.com
MAIL_SMTP_163_PORT=465
MAIL_SMTP_163_USER=
MAIL_SMTP_163_PASS=

# Gmail SMTP 配置（可选）
MAIL_SMTP_GMAIL_HOST=smtp.gmail.com
MAIL_SMTP_GMAIL_PORT=587
MAIL_SMTP_GMAIL_USER=
MAIL_SMTP_GMAIL_PASS=
