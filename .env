# 服务器配置
PORT=3000

# MySQL 数据库配置（请根据实际情况修改）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=yaotianxia

# JWT 密钥（请修改为随机字符串）
